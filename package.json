{
	"name": "vogelibizz",
	"version": "0.1.0",
	"private": true,
	"engines": {
		"node": "24.x",
		"bun": "1.3.4"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "bun run check && vite build",
		"preview": "vite preview",
		"test": "bun test",
		"cf-typegen": "wrangler types",
		"deploy": "bun run build && wrangler deploy",
		"check": "tsc --noEmit && bunx @biomejs/biome check --write src",
		"format": "bunx @biomejs/biome format --write .",
		"db:generate": "drizzle-kit generate",
		"db:studio": "drizzle-kit studio",
		"db:migrate": "bun run db:migrate:local",
		"db:migrate:local": "wrangler d1 migrations apply vogelibizz --local",
		"db:migrate:remote": "wrangler d1 migrations apply vogelibizz --remote",
		"db:seed": "bun run db:seed:local",
		"db:seed:generate": "bun run scripts/generate-d1-seed.ts",
		"db:seed:local": "wrangler d1 execute vogelibizz --local --file ./src/db/seeds/seed-full.sql",
		"db:seed:remote": "wrangler d1 execute vogelibizz --remote --file ./src/db/seeds/seed.sql",
		"db:init:local": "bun run db:migrate:local && bun run db:seed:local"
	},
	"dependencies": {
		"@auth/core": "0.34.3",
		"@custom-react-hooks/use-media-query": "1.5.1",
		"@fontsource-variable/inter": "^5.0.19",
		"@lukemorales/query-key-factory": "1.3.4",
		"@radix-ui/react-alert-dialog": "1.1.15",
		"@radix-ui/react-checkbox": "1.3.3",
		"@radix-ui/react-dialog": "1.1.15",
		"@radix-ui/react-dropdown-menu": "2.1.16",
		"@radix-ui/react-icons": "1.3.2",
		"@radix-ui/react-popover": "1.1.15",
		"@radix-ui/react-slot": "1.2.4",
		"@radix-ui/react-tooltip": "1.2.8",
		"@react-pdf/renderer": "4.3.2",
		"@tanstack/react-form": "1.33.0",
		"@tanstack/react-query": "5.90.19",
		"@tanstack/react-query-devtools": "5.91.2",
		"@tanstack/react-router": "^1.0.0",
		"@tanstack/react-start": "^1.0.0",
		"@tanstack/react-table": "8.21.3",
		"@tanstack/react-virtual": "3.13.12",
		"baseline-browser-mapping": "2.10.34",
		"caniuse-lite": "1.0.30001764",
		"class-variance-authority": "0.7.1",
		"cmdk": "1.1.1",
		"date-fns": "4.1.0",
		"drizzle-orm": "0.45.1",
		"drizzle-zod": "0.8.3",
		"easymde": "2.20.0",
		"js-cookie": "3.0.5",
		"lucide-react": "0.562.0",
		"marked-react": "3.0.2",
		"radix-ui": "1.6.2",
		"react": "19.2.3",
		"react-currency-input-field": "4.0.3",
		"react-dom": "19.2.3",
		"react-pdf-html": "2.1.5",
		"react-simplemde-editor": "5.2.0",
		"sonner": "2.0.7",
		"start-authjs": "1.0.2",
		"vaul": "1.1.2",
		"xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
		"zod": "4.3.5"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@cloudflare/vite-plugin": "1.23.1",
		"@tailwindcss/vite": "^4.1.18",
		"@types/js-cookie": "3.0.6",
		"@types/node": "25.0.9",
		"@types/react": "19.2.8",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "^5.1.2",
		"clsx": "2.1.1",
		"cross-env": "10.1.0",
		"drizzle-kit": "0.31.8",
		"lefthook": "2.1.9",
		"postcss": "8.5.6",
		"tailwind-merge": "3.4.0",
		"tailwindcss": "4.1.18",
		"tailwindcss-animate": "1.0.7",
		"typescript": "6.0.3",
		"@types/bun": "1.3.14",
		"vite": "^6.0.0",
		"vite-tsconfig-paths": "^5.1.4",
		"wrangler": "4.63.0"
	},
	"type": "module"
}
